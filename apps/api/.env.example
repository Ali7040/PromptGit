# ─── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
WEB_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://promptgit:promptgit@localhost:5432/promptgit

# ─── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────
JWT_SECRET=change-this-to-a-64-char-random-string-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── OAuth ────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-oauth-app-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── AI Models ────────────────────────────────────────
# Used by the AI Enhancement Engine and Eval Runner
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# ─── Object Storage (Cloudflare R2 or AWS S3) ─────────
STORAGE_ENDPOINT=https://your-account.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_BUCKET=promptgit-uploads
STORAGE_PUBLIC_URL=https://cdn.promptgit.dev

# ─── Payments (Lemon Squeezy) ─────────────────────────
LEMONSQUEEZY_API_KEY=your-api-key
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret
LEMONSQUEEZY_STORE_ID=12345

# ─── Email (Resend) ───────────────────────────────────
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=noreply@promptgit.dev

# ─── Search (Meilisearch — Phase 3+) ─────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=your-master-key

# ─── Monitoring ───────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn
